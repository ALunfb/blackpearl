# ── Steam Bot Account ─────────────────────────────
# Create a dedicated Steam account for the bot.
# Enable Steam Guard Mobile Authenticator and extract secrets.
STEAM_USERNAME=your_bot_username
STEAM_PASSWORD=your_bot_password
STEAM_SHARED_SECRET=base64_shared_secret_from_mafile
STEAM_IDENTITY_SECRET=base64_identity_secret_from_mafile

# Steam Web API key — get one at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_web_api_key

# ── Web Server ────────────────────────────────────
BOT_WEB_PORT=3001
BOT_WEB_URL=https://bot.blackpearl.gg
SESSION_SECRET=generate_a_random_32_char_string_here

# ── Data ──────────────────────────────────────────
# Path to the main site's listings-tracker.json
# If running on the same machine as the repo:
TRACKER_FILE_PATH=../data/listings-tracker.json
LISTINGS_FILE_PATH=../data/listings.json

# Path to the SQLite database (created automatically)
DB_PATH=./data/bot.sqlite

# ── Bot Behavior ──────────────────────────────────
# Max friends the bot will maintain
MAX_FRIENDS=250

# Quiet hours — no messages sent during this window (UTC)
QUIET_HOUR_START=2
QUIET_HOUR_END=6

# Rate limits
MAX_MESSAGES_PER_HOUR=60
MAX_MESSAGES_PER_DAY=300
PER_USER_COOLDOWN_MINUTES=1

# Snipe threshold — percentage below floor price to trigger snipe alert
SNIPE_THRESHOLD_PCT=15
